# ── Authentication ──────────────────────────────────────
GRAPHITI_API_KEY=local-graphiti

# ── Neo4j ───────────────────────────────────────────────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# ── LLM Provider ───────────────────────────────────────
# Supports "anthropic" or "openai" compatible APIs.
#
# Anthropic-style (Kimi, Claude, etc.):
LLM_API_STYLE=anthropic
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://api.kimi.com/coding
LLM_MODEL_NAME=kimi-for-coding
#
# OpenAI-style (Qwen, Moonshot, etc.):
# LLM_API_STYLE=openai
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus
#
# Optional: override Graphiti's internal "small" extraction model.
# LLM_SMALL_MODEL_NAME=

# ── Embedding (OpenAI-compatible) ──────────────────────
EMBEDDING_API_KEY=your_embedding_key
EMBEDDING_BASE_URL=
EMBEDDING_MODEL_NAME=text-embedding-3-small
# DashScope limits to 10 texts per batch; set this to enable auto-chunking:
# EMBEDDING_BATCH_SIZE=10

# ── Server ─────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
